# Admin Portal Environment Variables
# Copy this file to .env and fill in your values

# Flask Configuration
FLASK_SECRET_KEY=your-super-secret-key-here-change-this-in-production

# News API Keys (Optional - app works without these)
NEWS_API_KEY=your-news-api-key-from-newsapi.org
ALPHA_VANTAGE_KEY=your-alpha-vantage-key-for-stock-data

# Reddit API (Optional)
REDDIT_CLIENT_ID=your-reddit-client-id
REDDIT_CLIENT_SECRET=your-reddit-client-secret
REDDIT_USER_AGENT=AdminDashboard/1.0

# Twitter API (Optional)  
TWITTER_BEARER_TOKEN=your-twitter-bearer-token
